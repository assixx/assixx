{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Assixx Backend Production Build Configuration",

  // ============================================================
  // PRODUCTION BUILD CONFIG — Inherits ALL strict flags from
  // tsconfig.json (which extends tsconfig.base.json).
  //
  // Rule: This config MUST NOT weaken any strict flag.
  // It only adds production-specific exclusions.
  //
  // See ADR-041 for the full rationale.
  // ============================================================
  "extends": "./tsconfig.json",

  "compilerOptions": {
    // Production builds emit declaration files via composite,
    // but no source maps for declarations (smaller dist).
    "declarationMap": false
  },

  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/__tests__/**/*",
    "src/**/__tests__/**/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/routes/v1/**/*",
    "src/routes/mocks/**/*"
  ]
}
