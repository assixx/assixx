{
  "name": "assixx-backend",
  "version": "1.0.0",
  "description": "Assixx Multi-Tenant SaaS Backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest -c ../jest.config.js",
    "test:watch": "jest -c ../jest.config.js --watch",
    "test:coverage": "jest -c ../jest.config.js --coverage",
    "test:attachments": "jest -c ../jest.config.js --testPathPattern=attachments --verbose",
    "test:e2e": "jest --testPathPattern=e2e --runInBand",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "lint": "cd .. && eslint . --no-warn-ignored",
    "lint:fix": "cd .. && eslint . --fix --no-warn-ignored",
    "lint:fixnowarn": "cd .. && eslint . --fix --quiet --no-warn-ignored",
    "prettier": "prettier --check src/**/*.ts",
    "prettier:fix": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/run-migration.js",
    "db:seed": "node scripts/seed-database.js",
    "setup:dev": "npm run build && npm run db:migrate && npm run db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "nodejs",
    "typescript",
    "mysql"
  ],
  "author": "SCS Technik",
  "license": "MIT",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.10",
    "rate-limit-redis": "4.2.3",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "ws": "^8.18.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.11.1"
  }
}
