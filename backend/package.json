{
  "name": "assixx-backend",
  "version": "1.0.0",
  "description": "Assixx Multi-Tenant SaaS Backend",
  "main": "dist/nest/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'pnpm exec tsx src/nest/main.ts'",
    "dev:express": "nodemon --watch src --ext ts --exec 'pnpm exec tsx src/server.ts'",
    "build": "tsc",
    "start": "node dist/nest/main.js",
    "start:express": "node dist/server.js",
    "lint": "cd .. && eslint . --no-warn-ignored",
    "lint:fix": "cd .. && eslint . --fix --no-warn-ignored",
    "lint:fixnowarn": "cd .. && eslint . --fix --quiet --no-warn-ignored",
    "prettier": "prettier --check src/**/*.ts",
    "prettier:fix": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "nodejs",
    "typescript",
    "postgres"
  ],
  "author": "Assixx",
  "license": "ASSIXX PROPRIETARY LICENSE",
  "dependencies": {
    "@assixx/shared": "workspace:*",
    "@fastify/cookie": "11.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "9.4.0",
    "@fastify/static": "9.0.0",
    "@nest-lab/throttler-storage-redis": "1.1.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.13",
    "@nestjs/schedule": "6.1.0",
    "@nestjs/swagger": "11.2.5",
    "@nestjs/throttler": "6.5.0",
    "@sentry/nestjs": "^10.38.0",
    "@webundsoehne/nest-fastify-file-upload": "2.3.1",
    "@willsoto/nestjs-prometheus": "6.0.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fastify-multer": "2.0.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "nestjs-cls": "^6.2.0",
    "nestjs-pino": "4.5.0",
    "nestjs-zod": "^5.1.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.18.0",
    "pg-cursor": "^2.17.0",
    "pino": "^10.3.0",
    "pino-http": "11.0.0",
    "pino-loki": "3.0.0",
    "pino-roll": "4.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.23",
    "@types/node": "~24.10.10",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/pg-cursor": "2.7.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "pino-pretty": "13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.13.0"
  }
}
