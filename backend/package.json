{
  "name": "assixx-backend",
  "version": "0.4.13",
  "description": "Assixx Multi-Tenant SaaS Backend",
  "main": "dist/nest/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'pnpm exec tsx src/nest/main.ts'",
    "build": "tsc",
    "start": "node dist/nest/main.js",
    "lint": "cd .. && eslint . --no-warn-ignored",
    "lint:fix": "cd .. && eslint . --fix --no-warn-ignored",
    "lint:fixnowarn": "cd .. && eslint . --fix --quiet --no-warn-ignored",
    "prettier": "prettier --check src/**/*.ts",
    "prettier:fix": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "nodejs",
    "typescript",
    "postgres"
  ],
  "author": "Assixx",
  "license": "ASSIXX PROPRIETARY LICENSE",
  "dependencies": {
    "@assixx/shared": "workspace:*",
    "@fastify/cookie": "11.0.2",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/static": "9.1.3",
    "@nest-lab/throttler-storage-redis": "~1.2.0",
    "@nestjs/common": "~11.1.19",
    "@nestjs/config": "~4.0.4",
    "@nestjs/core": "~11.1.19",
    "@nestjs/jwt": "~11.0.2",
    "@nestjs/platform-fastify": "~11.1.19",
    "@nestjs/schedule": "~6.1.3",
    "@nestjs/throttler": "6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/nestjs": "~10.50.0",
    "@sentry/opentelemetry": "~10.50.0",
    "@webundsoehne/nest-fastify-file-upload": "2.3.1",
    "@willsoto/nestjs-prometheus": "6.1.0",
    "bcryptjs": "3.0.3",
    "content-disposition": "1.1.0",
    "dotenv": "~17.4.2",
    "fastify": "^5.8.5",
    "fastify-multer": "2.0.3",
    "ioredis": "~5.10.1",
    "jose": "6.2.3",
    "jsonwebtoken": "9.0.3",
    "mailchecker": "6.0.20",
    "nestjs-cls": "~6.2.0",
    "nestjs-pino": "~4.6.1",
    "nestjs-zod": "~5.3.0",
    "nodemailer": "~8.0.7",
    "pg": "~8.20.0",
    "pg-cursor": "~2.19.0",
    "pino": "~10.3.1",
    "pino-http": "11.0.0",
    "pino-loki": "3.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "~0.2.2",
    "rxjs": "~7.8.2",
    "uuid": "~14.0.0",
    "ws": "~8.20.0",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@types/content-disposition": "0.5.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "~24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "2.7.2",
    "@types/ws": "^8.18.1",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
