{
  "singleQuote": true,
  "printWidth": 100,
  "endOfLine": "lf",
  "experimentalTernaries": true,
  "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte",
        "singleAttributePerLine": true
      }
    }
  ]
}
