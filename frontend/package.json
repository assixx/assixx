{
  "name": "assixx-frontend",
  "version": "0.4.12",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm run format && (pnpm run lint:fix || true) && pnpm run check",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "build-storybook": "storybook build -o ../storybook-static -c .storybook",
    "stylelint": "stylelint \"**/*.{css,svelte}\" --cache --cache-location .stylelintcache",
    "stylelint:fix": "stylelint \"**/*.{css,svelte}\" --fix --cache --cache-location .stylelintcache",
    "stylelint:report": "stylelint \"**/*.{css,svelte}\" --formatter json > ../stylelint-report.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/html-vite": "^10.3.5",
    "@sveltejs/adapter-node": "~5.5.4",
    "@sveltejs/kit": "~2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/html-minifier-terser": "7.0.2",
    "@types/qrcode": "1.5.6",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "html-minifier-terser": "7.2.0",
    "postcss-html": "1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.5",
    "stylelint": "^17.9.1",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "svelte": "~5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "~4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@assixx/shared": "workspace:*",
    "@event-calendar/core": "^5.7.0",
    "@internationalized/date": "3.12.1",
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@sentry/sveltekit": "~10.50.0",
    "bits-ui": "~2.18.0",
    "dompurify": "3.4.1",
    "hash-wasm": "4.12.0",
    "marked": "18.0.2",
    "pino": "~10.3.1",
    "pino-loki": "3.0.0",
    "pino-pretty": "13.1.3",
    "qrcode": "1.5.4",
    "svelte-awesome-color-picker": "4.1.2",
    "svelte-easy-crop": "5.0.1"
  }
}
