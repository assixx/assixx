{
  "name": "assixx-frontend",
  "version": "0.4.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm run format && (pnpm run lint:fix || true) && pnpm run check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-node": "~5.5.4",
    "@sveltejs/kit": "~2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/html-minifier-terser": "7.0.2",
    "@types/qrcode": "1.5.6",
    "eslint": "^10.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "html-minifier-terser": "7.2.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "~5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "~4.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@assixx/shared": "workspace:*",
    "@event-calendar/core": "^5.6.1",
    "@internationalized/date": "3.12.0",
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "2.0.1",
    "@noble/hashes": "2.0.1",
    "@sentry/sveltekit": "~10.48.0",
    "bits-ui": "~2.17.3",
    "dompurify": "3.4.0",
    "hash-wasm": "4.12.0",
    "pino": "~10.3.1",
    "pino-loki": "3.0.0",
    "pino-pretty": "13.1.3",
    "qrcode": "1.5.4",
    "svelte-awesome-color-picker": "4.1.2",
    "svelte-easy-crop": "5.0.1"
  }
}
