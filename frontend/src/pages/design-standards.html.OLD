<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Design System - Assixx v1.0.0</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Critical Layout State -->
    <script>
      (function () {
        const sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        document.documentElement.setAttribute(
          'data-sidebar',
          sidebarCollapsed ? 'collapsed' : 'expanded',
        );
        document.documentElement.style.setProperty(
          '--sidebar-width',
          sidebarCollapsed ? '60px' : '250px',
        );
        document.documentElement.style.setProperty(
          '--content-margin',
          sidebarCollapsed ? '60px' : '250px',
        );
      })();
    </script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="/styles/lib/fontawesome.min.css" />

    <!-- Main Styles -->
    <link rel="stylesheet" href="/styles/tailwind.css" />
    <link rel="stylesheet" href="/styles/dashboard-theme.css" />

    <style>
      /* Page-specific styles */
      body {
        position: relative;
        background: #000;
        min-height: 100vh;
        overflow-x: hidden;
      }

      body::after {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: -1;
        background: linear-gradient(
          5deg,
          transparent 0%,
          rgba(0, 142, 255, 0.1) 25%,
          rgba(1, 0, 4, 0.51) 60%,
          rgba(0, 0, 4, 0.6) 90%,
          black 100%
        );
        pointer-events: none;
        content: '';
      }

      .ds-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 60px 40px;
      }

      .ds-header {
        text-align: center;
        margin-bottom: 80px;
      }

      .ds-title {
        font-size: 3rem;
        font-weight: 700;
        color: var(--color-white);
        margin: 0 0 16px 0;
        text-shadow: 0 0 30px rgba(33, 150, 243, 0.4);
      }

      .ds-subtitle {
        font-size: 1.25rem;
        color: var(--color-text-secondary);
        margin: 0;
      }

      .ds-version {
        display: inline-block;
        margin-top: 16px;
        padding: 6px 16px;
        background: rgba(33, 150, 243, 0.1);
        border: 1px solid rgba(33, 150, 243, 0.3);
        border-radius: 20px;
        color: var(--color-primary);
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.5px;
      }

      .ds-section {
        margin-bottom: 80px;
      }

      .ds-section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0 0 32px 0;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--color-primary);
        font-size: 2rem;
        font-weight: 600;
      }

      .ds-section-title::before {
        content: '';
        width: 4px;
        height: 32px;
        background: linear-gradient(180deg, var(--color-primary), var(--color-primary-light));
        border-radius: 2px;
      }

      .ds-card {
        backdrop-filter: blur(20px) saturate(180%);
        box-shadow: var(--shadow-glass);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-2xl);
        background: rgba(255, 255, 255, 0.02);
        padding: 32px;
        margin-bottom: 24px;
      }

      .ds-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-glass-hover);
        background: rgba(255, 255, 255, 0.03);
        transition: all var(--duration-normal) var(--ease-out);
      }

      .ds-card-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--color-white);
        margin: 0 0 20px 0;
      }

      .ds-card-description {
        color: var(--color-text-secondary);
        margin: 0 0 24px 0;
        line-height: 1.6;
      }

      .ds-showcase {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: center;
        padding: 32px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: var(--radius-lg);
        margin-bottom: 16px;
      }

      .ds-code {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-lg);
        padding: 20px;
        overflow-x: auto;
      }

      .ds-code code {
        color: #64b5f6;
        font-size: 0.875rem;
        font-family: 'SF Mono', 'Consolas', monospace;
        line-height: 1.6;
      }

      .ds-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
      }

      .ds-divider {
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.2),
          transparent
        );
        margin: 48px 0;
      }

      .ds-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-text-secondary);
        margin-bottom: 8px;
      }

      .ds-note {
        display: flex;
        gap: 12px;
        padding: 16px;
        background: rgba(33, 150, 243, 0.05);
        border-left: 3px solid var(--color-primary);
        border-radius: var(--radius-md);
        margin-top: 16px;
      }

      .ds-note-icon {
        color: var(--color-primary);
        flex-shrink: 0;
      }

      .ds-note-content {
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        line-height: 1.6;
      }

      .ds-note-content strong {
        color: var(--color-white);
      }
    </style>
  </head>
  <body>
    <div class="ds-container">
      <!-- Header -->
      <div class="ds-header">
        <h1 class="ds-title">Assixx Design System</h1>
        <p class="ds-subtitle">Living Style Guide • Component Playground</p>
        <span class="ds-version">Version 1.0.0 - Best Practice 2025</span>
      </div>

      <!-- Button System -->
      <section class="ds-section">
        <h2 class="ds-section-title">Button System</h2>

        <!-- Primary Buttons -->
        <div class="ds-card">
          <h3 class="ds-card-title">Primary Buttons</h3>
          <p class="ds-card-description">
            Main call-to-action buttons for forms, dialogs, and important actions. Features blue
            gradient background with shine effect.
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-primary">Save Changes</button>
            <button class="btn btn-primary">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M14,13V17H10V13H7L12,8L17,13M19.35,10.03C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.03C2.34,8.36 0,10.9 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.03Z"
                />
              </svg>
              Upload File
            </button>
            <button class="btn btn-primary btn-sm">Small</button>
            <button class="btn btn-primary">Medium</button>
            <button class="btn btn-primary btn-lg">Large</button>
            <button class="btn btn-primary" disabled>Disabled</button>
          </div>

          <span class="ds-label">Code Example</span>
          <div class="ds-code">
            <code>&lt;button class="btn btn-primary"&gt;Save Changes&lt;/button&gt;</code>
          </div>

          <div class="ds-note">
            <span class="ds-note-icon">
              <i class="fas fa-info-circle"></i>
            </span>
            <div class="ds-note-content">
              <strong>When to use:</strong> Primary form submit (Save, Create, Send), main dialog
              action (Confirm, Submit), feature CTAs in content areas. <br /><br />
              <strong>Design:</strong> Blue gradient background • White text • Shine animation on
              hover • 2px lift effect
            </div>
          </div>
        </div>

        <!-- Primary First-Level -->
        <div class="ds-card">
          <h3 class="ds-card-title">Primary First-Level (Hero CTAs)</h3>
          <p class="ds-card-description">
            Special variant for landing pages and hero sections. <strong>Transparent background</strong> with
            shadow-only boundary creates elegant, minimalist look.
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-primary-first">Get Started</button>
            <button class="btn btn-primary-first">Jetzt registrieren</button>
            <button class="btn btn-primary-first">Login</button>
            <button class="btn btn-primary-first btn-lg">Hero CTA Large</button>
          </div>

          <span class="ds-label">Code Example</span>
          <div class="ds-code">
            <code>&lt;button class="btn btn-primary-first"&gt;Get Started&lt;/button&gt;</code>
          </div>

          <div class="ds-note">
            <span class="ds-note-icon">
              <i class="fas fa-lightbulb"></i>
            </span>
            <div class="ds-note-content">
              <strong>CRITICAL:</strong> <code>background: none !important</code> - This is
              intentional! Shadow-only creates visual boundary. <br /><br />
              <strong>When to use:</strong> Landing page hero • Login page • Marketing CTAs in
              header <br /><br />
              <strong>Design Philosophy:</strong> "Less is more" - transparency feels premium and
              draws attention without heavy background.
            </div>
          </div>
        </div>

        <!-- Secondary Buttons -->
        <div class="ds-card">
          <h3 class="ds-card-title">Secondary Buttons</h3>
          <p class="ds-card-description">
            Alternative/cancel actions. Outline style with glassmorphism maintains visual hierarchy
            below primary buttons.
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-secondary">Cancel</button>
            <button class="btn btn-secondary">Back</button>
            <button class="btn btn-secondary">More Info</button>
            <button class="btn btn-secondary btn-sm">Small</button>
            <button class="btn btn-secondary btn-lg">Large</button>
          </div>

          <span class="ds-label">Code Example</span>
          <div class="ds-code">
            <code>&lt;button class="btn btn-secondary"&gt;Cancel&lt;/button&gt;</code>
          </div>
        </div>

        <!-- Danger Buttons -->
        <div class="ds-card">
          <h3 class="ds-card-title">Danger Buttons</h3>
          <p class="ds-card-description">
            Destructive actions (delete, remove). Red gradient with solid style provides high
            visibility and intentional friction.
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-danger">Delete User</button>
            <button class="btn btn-danger">Remove Item</button>
            <button class="btn btn-danger">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                />
              </svg>
              Delete
            </button>
            <button class="btn btn-danger btn-sm">Small Danger</button>
          </div>

          <span class="ds-label">Code Example</span>
          <div class="ds-code">
            <code>&lt;button class="btn btn-danger"&gt;Delete User&lt;/button&gt;</code>
          </div>

          <div class="ds-note">
            <span class="ds-note-icon">
              <i class="fas fa-exclamation-triangle"></i>
            </span>
            <div class="ds-note-content">
              <strong>Best Practice:</strong> Always confirm before danger actions! Show modal: "Are
              you sure...?", require re-type of name for critical operations, provide undo when
              possible.
            </div>
          </div>
        </div>

        <!-- Success Buttons -->
        <div class="ds-card">
          <h3 class="ds-card-title">Success Buttons</h3>
          <p class="ds-card-description">
            Positive confirmation actions. Green gradient communicates success/approval context.
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-success">Approve Request</button>
            <button class="btn btn-success">Confirm</button>
            <button class="btn btn-success">Mark as Complete</button>
          </div>

          <span class="ds-label">Code Example</span>
          <div class="ds-code">
            <code>&lt;button class="btn btn-success"&gt;Approve Request&lt;/button&gt;</code>
          </div>
        </div>

        <!-- Status Toggle Buttons -->
        <div class="ds-card">
          <h3 class="ds-card-title">Status Toggle Buttons</h3>
          <p class="ds-card-description">
            Activate/deactivate status toggles. <strong>Important:</strong> Button shows OPPOSITE
            of current state (inverse relationship).
          </p>

          <span class="ds-label">Visual Examples</span>
          <div class="ds-showcase">
            <button class="btn btn-status-active">Deaktivieren</button>
            <button class="btn btn-status-inactive">Aktivieren</button>
            <button class="btn btn-status-active btn-sm">Small Deactivate</button>
            <button class="btn btn-status-inactive btn-sm">Small Activate</button>
          </div>

          <span class="ds-label">Code Examples</span>
          <div class="ds-code">
            <code
              >&lt;!-- User is currently ACTIVE → show deactivate (orange) --&gt; <br />
&lt;button class="btn btn-status-active"&gt;Deaktivieren&lt;/button&gt; <br /><br />
&lt;!-- User is currently INACTIVE → show activate (green) --&gt; <br />
&lt;button class="btn btn-status-inactive"&gt;Aktivieren&lt;/button&gt;</code
            >
          </div>

          <div class="ds-note">
            <span class="ds-note-icon">
              <i class="fas fa-exchange-alt"></i>
            </span>
            <div class="ds-note-content">
              <strong>Logic:</strong> Inverse relationship - button shows OPPOSITE of current state.
              <br /><br />
              <strong>Color Psychology:</strong> Orange = Warning (deactivating is caution) • Green
              = Positive (activating is go)
            </div>
          </div>
        </div>

        <div class="ds-divider"></div>

        <!-- Button Combinations -->
        <div class="ds-card">
          <h3 class="ds-card-title">Button Groups & Layouts</h3>
          <p class="ds-card-description">Common button combinations and patterns.</p>

          <span class="ds-label">Modal Actions (Primary + Secondary)</span>
          <div class="ds-showcase">
            <button class="btn btn-primary">Confirm</button>
            <button class="btn btn-secondary">Cancel</button>
          </div>

          <span class="ds-label">Destructive Confirmation</span>
          <div class="ds-showcase">
            <button class="btn btn-danger">Delete</button>
            <button class="btn btn-secondary">Cancel</button>
          </div>

          <span class="ds-label">Full Width (Forms)</span>
          <div class="ds-showcase" style="display: block">
            <button class="btn btn-primary btn-block" style="margin-bottom: 12px">
              Submit Form
            </button>
            <button class="btn btn-secondary btn-block">Cancel</button>
          </div>

          <span class="ds-label">Icon Only Buttons</span>
          <div class="ds-showcase">
            <button class="btn btn-primary btn-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
              </svg>
            </button>
            <button class="btn btn-secondary btn-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
              </svg>
            </button>
            <button class="btn btn-danger btn-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" />
              </svg>
            </button>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <div style="text-align: center; padding-top: 60px; border-top: 1px solid rgba(255, 255, 255, 0.1)">
        <p style="color: var(--color-text-secondary); margin: 0">
          Assixx Design System v1.0.0 • Best Practice 2025
        </p>
        <p style="color: var(--color-text-secondary); font-size: 0.875rem; margin: 8px 0 0 0">
          Built with ❤️ by Simon Öztürk & Claude AI
        </p>
      </div>
    </div>

    <!-- Scripts for interactivity (future) -->
    <script>
      // Future: Add interactive demos (loading states, ripple effects, etc.)
      console.log('Assixx Design System v1.0.0 loaded');
      console.log('Button variants available: 6');
      console.log('Documentation: /frontend/src/design-system/README.md');
    </script>
  </body>
</html>
