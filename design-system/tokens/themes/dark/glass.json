{
  "glass": {
    "background": {
      "value": "rgba(255, 255, 255, {glass.opacity.subtle})",
      "description": "Glass background for dark theme"
    },
    "background-hover": {
      "value": "rgba(255, 255, 255, {glass.opacity.light})",
      "description": "Glass hover background for dark theme"
    },
    "background-active": {
      "value": "rgba(255, 255, 255, {glass.opacity.medium})",
      "description": "Glass active background for dark theme"
    },
    "border": {
      "value": "rgba(255, 255, 255, {glass.opacity.medium})",
      "description": "Glass border for dark theme"
    },
    "backdrop": {
      "value": "blur({glass.blur.lg}) saturate({glass.saturate.high})",
      "description": "Glass backdrop filter for dark theme"
    }
  }
}
