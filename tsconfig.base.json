{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Assixx Base Configuration - Shared TypeScript Rules",
  "compilerOptions": {
    // ============================================================
    // STRICT TYPE CHECKING
    // Power of Ten Rules: https://spinroot.com/gerard/pdf/P10.pdf
    // See: docs/POWER-OF-TEN-RULES.md - Regel 10: Zero Warnings
    // ============================================================
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true, // Power of Ten: Klassen müssen initialisiert sein
    "noImplicitThis": true,
    "noImplicitAny": true,
    "alwaysStrict": true, // redundant in TS 6.0 (always-on), kept for documentation
    "useUnknownInCatchVariables": true, // Power of Ten: catch(error) ist unknown, nicht any
    "allowUnusedLabels": false, // Power of Ten Regel 10: Prevent dead code (unused labels)
    "allowUnreachableCode": false, // Power of Ten Regel 10: Prevent dead code (unreachable statements)

    // ============================================================
    // CODE QUALITY & UNUSED CODE DETECTION
    // Power of Ten Regel 7: Return-Values prüfen, Parameter validieren
    // ============================================================
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true, // Power of Ten: override keyword erzwingen
    // Power of Ten Regel 10: undefined vs "not defined" unterscheiden
    // See: https://www.typescriptlang.org/tsconfig/exactOptionalPropertyTypes.html
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true, // Power of Ten: arr[i] ist T | undefined - WICHTIG für Runtime-Safety
    // Power of Ten Regel 10: Force bracket notation for index signatures
    // Ensures explicit awareness when accessing dynamic keys
    "noPropertyAccessFromIndexSignature": true,
    // TS 5.6+: catches typo'd or missing side-effect imports (e.g.
    // `import "./missing"`). Pure strictness gain, no semantic change.
    "noUncheckedSideEffectImports": true,
    // TS 5.6+: built-in iterators (Map, Set, Array, generators) return
    // IteratorResult<T, BuiltinIteratorReturn = undefined> instead of
    // IteratorResult<T, any>. Catches bugs around `.next()` usage.
    "strictBuiltinIteratorReturn": true,
    // verbatimModuleSyntax intentionally NOT enabled (yet).
    // Surfacing it would produce 41 TS1484 errors across 30+ NestJS
    // files where type-only interfaces (OnModuleInit, CanActivate,
    // ExecutionContext, etc.) are imported via runtime syntax.
    // Tracking as a separate refactor — see ADR-041 § Open Items.

    // ============================================================
    // TARGET & LIBRARY
    // target ES2022 keeps emit compatible with older runtimes;
    // lib ES2024 enables IntelliSense for newer APIs that Node 24
    // and modern browsers natively support (Object.groupBy,
    // Promise.withResolvers, Array.fromAsync, etc.).
    // Note: Individual projects add DOM for browser targets.
    // ============================================================
    "target": "ES2022",
    "lib": ["ES2024"],
    // downlevelIteration removed — hard-deprecated in TS 6.0,
    // and unnecessary with target ES2022 (iteration natively supported).

    // ============================================================
    // MODULE SYSTEM
    // Note: 'module' and 'moduleResolution' are set per-project
    // Backend uses NodeNext, Frontend uses ESNext/bundler
    // ============================================================
    "resolveJsonModule": true,
    "esModuleInterop": true, // redundant in TS 6.0 (always-on), kept for documentation
    "allowSyntheticDefaultImports": true, // redundant in TS 6.0 (always-on), kept for documentation

    // ============================================================
    // FILE SYSTEM & CASING
    // Critical for cross-platform development (Windows/Mac/Linux)
    // ============================================================
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // ============================================================
    // OUTPUT CONFIGURATION
    // Source maps for debugging
    // ============================================================
    "sourceMap": true,
    "removeComments": true,

    // ============================================================
    // JAVASCRIPT SUPPORT
    // Allow .js files in TypeScript projects
    // ============================================================
    "allowJs": true,
    "checkJs": false
  }
}
