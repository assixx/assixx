#!/bin/sh
# Pre-commit hook for Assixx - Secret Detection
# Prevents accidental commit of hardcoded secrets
#
# Created: 2026-01-13
# Migrated to Husky: 2026-01-13
# Bypass: git commit --no-verify (use with caution!)
#
# NOTE: This script is POSIX-compatible (no bash arrays)
# because Husky runs hooks with /bin/sh

set -e

# Colors for output (POSIX compatible)
RED='¥033[0;31m'
YELLOW='¥033[1;33m'
GREEN='¥033[0;32m'
NC='¥033[0m'

printf "${YELLOW}[pre-commit]${NC} Checking for potential secrets...¥n"

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    printf "${GREEN}[pre-commit]${NC} No files staged, skipping.¥n"
    exit 0
fi

# Filter out safe files using grep -v with multiple patterns
FILES_TO_CHECK=$(echo "$STAGED_FILES" | grep -v ¥
    -e '¥.md$' ¥
    -e '¥.example$' ¥
    -e '¥.sample$' ¥
    -e '¥.test¥.ts$' ¥
    -e '¥.spec¥.ts$' ¥
    -e '¥.d¥.ts$' ¥
    -e 'pnpm-lock¥.yaml$' ¥
    -e 'package-lock¥.json$' ¥
    -e '¥.gitignore$' ¥
    -e '¥.prettierrc' ¥
    -e 'eslint¥.config' ¥
    2>/dev/null || true)

if [ -z "$FILES_TO_CHECK" ]; then
    printf "${GREEN}[pre-commit]${NC} All staged files are safe patterns.¥n"
    exit 0
fi

FOUND_SECRETS=0
PROBLEM_FILES=""

# Check each file for secret patterns
for file in $FILES_TO_CHECK; do
    # Skip if file doesn't exist
    if [ ! -f "$file" ]; then
        continue
    fi

    # Get staged content
    CONTENT=$(git show ":$file" 2>/dev/null || true)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    # Pattern 1: Password assignments with quoted values (8+ chars)
    if echo "$CONTENT" | grep -iE '(password|passwd|pwd)¥s*[:=]¥s*["¥x27][^"¥x27]{8,}["¥x27]' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (password pattern)"
    fi

    # Pattern 2: Secret/API key assignments with quoted values
    if echo "$CONTENT" | grep -iE '(secret|api_key|apikey|api-key)¥s*[:=]¥s*["¥x27][^"¥x27]{8,}["¥x27]' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (secret/api_key pattern)"
    fi

    # Pattern 3: JWT tokens (eyJ... pattern)
    if echo "$CONTENT" | grep -iE '(token|auth_token|access_token|refresh_token)¥s*[:=]¥s*["¥x27]eyJ[^"¥x27]+["¥x27]' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (JWT token pattern)"
    fi

    # Pattern 4: Private keys
    if echo "$CONTENT" | grep -iE '(private_key|privatekey)¥s*[:=]¥s*["¥x27]-----BEGIN' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (private key pattern)"
    fi

    # Pattern 5: AWS Access Key
    if echo "$CONTENT" | grep -E 'AKIA[0-9A-Z]{16}' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (AWS key pattern)"
    fi

    # Pattern 6: OpenAI API Key
    if echo "$CONTENT" | grep -E 'sk-[a-zA-Z0-9]{24,}' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (OpenAI key pattern)"
    fi

    # Pattern 7: GitHub Personal Access Token
    if echo "$CONTENT" | grep -E 'ghp_[a-zA-Z0-9]{36}' > /dev/null 2>&1; then
        FOUND_SECRETS=1
        PROBLEM_FILES="$PROBLEM_FILES¥n  - $file (GitHub token pattern)"
    fi
done

if [ $FOUND_SECRETS -eq 1 ]; then
    printf "¥n"
    printf "${RED}========================================${NC}¥n"
    printf "${RED}  POTENTIAL SECRET DETECTED!${NC}¥n"
    printf "${RED}========================================${NC}¥n"
    printf "¥n"
    printf "Files with potential secrets:${PROBLEM_FILES}¥n"
    printf "¥n"
    printf "${YELLOW}Actions:${NC}¥n"
    printf "  1. Review the flagged files for hardcoded secrets¥n"
    printf "  2. Move secrets to .env files (not committed)¥n"
    printf "  3. Use environment variables instead¥n"
    printf "¥n"
    printf "${YELLOW}If this is a false positive:${NC}¥n"
    printf "  git commit --no-verify¥n"
    printf "¥n"
    exit 1
fi

printf "${GREEN}[pre-commit]${NC} No secrets detected. Proceeding with commit.¥n"
exit 0
