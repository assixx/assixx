{
  "name": "assixx",
  "version": "0.4.9",
  "type": "module",
  "main": "backend/dist/nest/main.js",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [],
    "overrides": {
      "fastify": "^5.7.1",
      "tmp": "^0.2.4",
      "axios@<1.12.0": ">=1.12.0",
      "validator@<13.15.20": ">=13.15.20",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "esbuild@<0.27.0": ">=0.27.0",
      "tar@<7.5.2": ">=7.5.2",
      "express@>=5.0.0 <5.2.0": ">=5.2.0",
      "jws@<3.2.3": ">=3.2.3",
      "cookie@<0.7.0": ">=0.7.0",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "storybook@>=10.0.0 <10.1.10": ">=10.1.10",
      "qs@<6.14.1": ">=6.14.1",
      "diff@<8.0.3": ">=8.0.3",
      "devalue@>=5.1.0 <5.6.2": ">=5.6.2",
      "svelte@>=5.46.0 <=5.46.3": ">=5.46.4",
      "@sveltejs/kit@>=2.49.0 <=2.49.4": ">=2.49.5",
      "devalue@>=5.3.0 <=5.6.1": ">=5.6.2",
      "@sveltejs/adapter-node@>=5.4.1 <=5.5.0": ">=5.5.1",
      "@sveltejs/kit@>=2.19.0 <=2.49.4": ">=2.49.5",
      "fast-xml-parser@>=4.3.6 <=5.3.3": ">=5.3.4",
      "fastify@<=5.7.2": ">=5.7.3",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "minimatch@<10.2.1": ">=10.2.1",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "flatted@<=3.4.1": ">=3.4.2",
      "path-to-regexp@<8.4.0": ">=8.4.0",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "node backend/dist/nest/main.js",
    "start:prod": "node backend/dist/nest/main.js",
    "dev": "concurrently \"pnpm run dev:backend:nest\" \"pnpm run dev:frontend\"",
    "predev:svelte": "./scripts/free-port.sh 5173",
    "dev:svelte": "cd frontend && pnpm run dev",
    "predev:backend:nest": "./scripts/free-port.sh 3002",
    "dev:backend:nest": "cd backend && pnpm run build && nodemon --watch src --ext ts --exec 'pnpm run build && node dist/nest/main.js'",
    "dev:frontend": "cd frontend && pnpm run dev",
    "storybook": "storybook dev -p 6006 -c frontend/.storybook",
    "build-storybook": "storybook build -o storybook-static -c frontend/.storybook",
    "build": "pnpm run build:ts && pnpm run build:frontend",
    "build:prod": "NODE_ENV=production pnpm run build",
    "build:ts": "cd backend && tsc -p tsconfig.build.json",
    "build:frontend": "cd frontend && pnpm run build",
    "watch:ts": "tsc --watch",
    "install:all": "pnpm install && cd frontend && pnpm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:frontend": "cd frontend && NODE_OPTIONS='--max-old-space-size=8192' eslint .",
    "lint:frontend:fix": "cd frontend && NODE_OPTIONS='--max-old-space-size=8192' eslint . --fix",
    "lint:all": "pnpm run lint && pnpm run lint:frontend",
    "lint:all:fix": "pnpm run lint:fix && pnpm run lint:frontend:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:report": "eslint . --format json > eslint-report.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui --watch",
    "type-check": "tsc --noEmit -p shared && tsc --noEmit -p frontend && tsc --noEmit -p backend && tsc --noEmit -p backend/test",
    "type-coverage": "pnpm exec type-coverage",
    "check": "tsc --noEmit -p frontend && tsc --noEmit -p backend",
    "lint:ts": "eslint backend/src/**/*.ts",
    "test:all": "pnpm run check && pnpm run lint:ts && pnpm run format:check",
    "fix:all": "pnpm run format && pnpm run lint:fix && pnpm run stylelint:fix",
    "check:all": "pnpm run format && pnpm run lint:fix && pnpm run type-check && pnpm run stylelint",
    "validate:all": "F=0; echo '=== VALIDATE ALL ===' ; pnpm run format || F=1 ; echo '\\n=== Prettier Frontend (Tailwind) ===' ; (cd frontend && pnpm run format) || F=1 ; echo '\\n=== ESLint Backend ===' ; pnpm run lint:fix || F=1 ; echo '\\n=== ESLint Frontend ===' ; pnpm run lint:frontend:fix || F=1 ; echo '\\n=== TypeScript Check ===' ; pnpm run type-check || F=1 ; echo '\\n=== Svelte Check ===' ; (cd frontend && pnpm run check) || F=1 ; echo '\\n=== Stylelint ===' ; pnpm run stylelint:fix || F=1 ; echo '' ; if [ $F -ne 0 ]; then echo '=== VALIDATE ALL FAILED ==='; exit 1; fi ; echo '=== VALIDATE ALL PASSED ==='",
    "stylelint": "stylelint \"**/*.{css,svelte}\" --cache --cache-location .stylelintcache",
    "stylelint:fix": "stylelint \"**/*.{css,svelte}\" --fix --cache --cache-location .stylelintcache",
    "stylelint:report": "stylelint \"**/*.{css,svelte}\" --formatter json > stylelint-report.json",
    "test:api": "vitest run --project api",
    "test:unit:leaks": "vitest run --project unit --detect-async-leaks",
    "test:permission": "vitest run --project permission",
    "prepare": "husky",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "db:migrate": "node-pg-migrate -f .node-pg-migraterc.json -m database/migrations",
    "db:migrate:up": "node-pg-migrate up -f .node-pg-migraterc.json -m database/migrations",
    "db:migrate:down": "node-pg-migrate down -f .node-pg-migraterc.json -m database/migrations",
    "db:migrate:create": "node-pg-migrate create -j ts -f .node-pg-migraterc.json -m database/migrations",
    "db:migrate:redo": "node-pg-migrate redo -f .node-pg-migraterc.json -m database/migrations",
    "db:migrate:dry": "node-pg-migrate up --dry-run -f .node-pg-migraterc.json -m database/migrations",
    "db:seed": "./scripts/run-seeds.sh",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-root-version.mjs",
    "changeset:tag": "VERSION=$(node -p \"require('./package.json').version\") && git tag -a \"v$VERSION\" -m \"v$VERSION\"",
    "changeset:status": "changeset status"
  },
  "keywords": [
    "assixx",
    "saas",
    "enterprise",
    "document-management"
  ],
  "author": "Simon Öztürk <info@scs-technik.de>",
  "license": "Proprietary",
  "private": true,
  "description": "Assixx SaaS-Plattform für Industriefirmen - Server-Komponente",
  "dependencies": {
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "@zxcvbn-ts/language-de": "3.0.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/html-vite": "^10.3.4",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vitest/ui": "^4.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-storybook": "^10.3.4",
    "husky": "9.1.7",
    "knip": "^6.3.0",
    "markdownlint-cli": "^0.48.0",
    "node-pg-migrate": "8.0.4",
    "nodemon": "^3.1.14",
    "postcss-html": "1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-svelte": "^3.5.1",
    "storybook": "^10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
