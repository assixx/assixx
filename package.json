{
  "name": "assixx",
  "version": "1.0.0",
  "type": "module",
  "main": "backend/src/server.ts",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=10.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "overrides": {
      "tmp": "^0.2.4",
      "vite@>=7.1.0 <=7.1.4": ">=7.1.5",
      "axios@<1.12.0": ">=1.12.0",
      "vite@>=7.1.0 <=7.1.10": ">=7.1.11",
      "validator@<13.15.20": ">=13.15.20",
      "js-yaml@<4.1.1": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "esbuild@<0.27.0": ">=0.27.0",
      "tar@<7.5.2": ">=7.5.2",
      "test-exclude": "^7.0.1",
      "express@>=5.0.0 <5.2.0": ">=5.2.0",
      "jws@<3.2.3": ">=3.2.3"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "node dist/backend/src/server.js",
    "start:prod": "node dist/backend/src/server.js",
    "dev": "concurrently \"pnpm run dev:backend:ts\" \"pnpm run dev:frontend\"",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:backend:ts": "nodemon --exec \"tsx\" backend/src/server.ts",
    "dev:frontend": "cd frontend && pnpm run dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "build": "pnpm run build:ts && pnpm run build:frontend",
    "build:prod": "NODE_ENV=production pnpm run build",
    "build:ts": "cd backend && tsc -p tsconfig.build.json",
    "build:frontend": "cd frontend && pnpm run build",
    "watch:ts": "tsc --watch",
    "install:all": "pnpm install && cd frontend && pnpm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:report": "eslint . --format json > eslint-report.json",
    "security:check": "eslint . --ext .ts,.tsx,.js,.jsx --plugin security,no-unsanitized",
    "security:report": "eslint . --ext .ts,.tsx,.js,.jsx --plugin security,no-unsanitized --format json > security-report.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --coverage",
    "type-check": "tsc --noEmit -p frontend && tsc --noEmit -p backend",
    "type-check:prod": "sh scripts/check-types-prod.sh",
    "type-coverage": "pnpm exec type-coverage",
    "check": "tsc --noEmit -p frontend && tsc --noEmit -p backend",
    "lint:ts": "eslint backend/src/**/*.ts",
    "test:all": "pnpm run check && pnpm run lint:ts && pnpm run format:check",
    "fix:all": "pnpm run format && pnpm run lint:fix && pnpm run stylelint:fix",
    "check:all": "pnpm run format && pnpm run lint:fix && pnpm run type-check && pnpm run stylelint",
    "stylelint": "stylelint \"**/*.{css,scss}\" --cache --cache-location .stylelintcache",
    "stylelint:fix": "stylelint \"**/*.{css,scss}\" --fix --cache --cache-location .stylelintcache",
    "stylelint:report": "stylelint \"**/*.{css,scss}\" --formatter json > stylelint-report.json",
    "css:analyze": "node scripts/analyze-css.cjs",
    "css:analyze:verbose": "node scripts/analyze-css.cjs --verbose",
    "css:analyze:file": "node scripts/analyze-css.cjs --file",
    "test:api": "cd api-tests && bru run auth users departments teams notifications blackboard calendar kvp machines surveys areas settings roles features chat documents shifts --env local",
    "test:api:auth": "cd api-tests && bru run auth --env local"
  },
  "keywords": [
    "assixx",
    "saas",
    "enterprise",
    "document-management"
  ],
  "author": "Simon Öztürk <info@scs-technik.de>",
  "license": "Proprietary",
  "private": true,
  "description": "Assixx SaaS-Plattform für Industriefirmen - Server-Komponente",
  "dependencies": {
    "@types/express-serve-static-core": "^5.1.0",
    "@types/qs": "^6.14.0",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "@zxcvbn-ts/language-de": "3.0.2",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "nodemailer": "^7.0.12",
    "redis": "^5.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@storybook/addon-docs": "10.1.11",
    "@storybook/addon-links": "10.1.11",
    "@storybook/builder-vite": "10.1.11",
    "@storybook/html-vite": "10.1.11",
    "@swc/core": "^1.15.8",
    "@swc/helpers": "^0.5.18",
    "@tailwindcss/vite": "4.1.18",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "~25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@usebruno/cli": "2.15.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-storybook": "10.1.11",
    "eslint-plugin-tsdoc": "^0.5.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "jest": "^30.2.0",
    "markdownlint-cli": "^0.47.0",
    "nodemon": "^3.1.11",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-css-order": "^2.1.2",
    "purgecss": "7.0.2",
    "storybook": "10.1.11",
    "stylelint": "^16.26.1",
    "stylelint-config-clean-order": "^8.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^6.14.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
