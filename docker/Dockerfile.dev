# Development Dockerfile für Live-Reload
FROM node:24.11.1-alpine

# Install development tools
RUN apk add --no-cache curl jq

# Install pnpm and development tools globally
# Using npm only to bootstrap pnpm, then pnpm handles everything else
RUN npm install -g pnpm@latest tsx nodemon

# Arbeitsverzeichnis
WORKDIR /app

# Package files kopieren - pnpm workspace braucht alle package.json VORHER
COPY package.json ./
COPY pnpm-lock.yaml ./
COPY pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/
COPY backend/package.json ./backend/

# EINMAL installieren - pnpm findet automatisch alle Workspaces (frontend + backend)
# onlyBuiltDependencies in package.json verhindert build scripts während Docker build
RUN pnpm install --frozen-lockfile

# Der Rest wird über Volumes gemountet

# Port
EXPOSE 3000

# Development command
CMD ["pnpm", "run", "dev"]
