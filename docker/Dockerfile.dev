# syntax=docker/dockerfile:1
# =============================================================================
# Assixx Backend - Development Dockerfile
# =============================================================================
# Single-stage build for development with live-reload
#
# BuildKit Optimizations:
# - Cache mounts for pnpm store (faster rebuilds)
# =============================================================================

# Node version is configurable via docker-compose.yml build args.
#
# IMPORTANT: the backend image uses Debian slim (glibc), NOT Alpine (musl).
# Rationale: musl's DNS resolver ships without EDNS0 support and has a long
# history of dual-stack quirks with Docker's embedded DNS (127.0.0.11) —
# `getaddrinfo(AF_UNSPEC)` can drop the A-answer and return AAAA-only, which
# then fails with ENETUNREACH on v4-only bridges. Affected every outbound
# fetch() (OAuth token exchange, JWKS, any future third-party HTTPS).
# glibc implements EDNS0, TCP fallback, and RFC-compliant dual-stack, so the
# whole failure class disappears by choosing the standards-compliant libc.
# See moby#41651, bell-sw "Alpine DNS issues", alpinelinux/docker-alpine#399.
ARG NODE_VERSION=24.15.0-bookworm-slim
FROM node:${NODE_VERSION}
LABEL org.opencontainers.image.authors="Assixx"

# Install development tools (Debian/apt, not Alpine/apk)
# `ripgrep` is required by the architectural-pattern tests in
# `shared/src/architectural.test.ts` — `grepFiles()` shells out to `rg` and
# now fails loudly when it is missing (previously masked exit 127 with
# `2>/dev/null || true`, turning every grep-based rule into a false-negative).
# Discovered 2026-04-25; keeping `rg` baked into the dev image guarantees
# Dev/CI parity for `pnpm run test:unit` whether run on host or in container.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl jq ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm globally (pinned version matching packageManager field)
# Note: CVE-2025-64118 (tar) is fixed via pnpm override in package.json
# Fix CVE-2025-64756: Update npm to get patched glob (>=11.1.0)
# pnpm AND npm parameterised — versions configurable via docker-compose
# build args / docker/.env (Single Source of Truth).
# See ADR-027 §"Amendment 2026-04-27" (npm parameterisation).
ARG PNPM_VERSION=10.33.2
ARG NPM_VERSION=11.13.0
RUN npm install -g "npm@${NPM_VERSION}" "pnpm@${PNPM_VERSION}"

WORKDIR /app

# Package files — pnpm workspace needs all package.json before install
COPY package.json .npmrc pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/
COPY backend/package.json ./backend/
COPY shared/package.json ./shared/

# Shared source (inject-workspace-packages needs source at install time)
COPY shared/ ./shared/

# Install all workspace dependencies with BuildKit cache mount
# Cache persists between builds, so unchanged packages don't need re-download
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Create writable directories and fix permissions
# Only chown specific dirs (not node_modules — would take 100+ seconds!)
RUN mkdir -p /app/logs /app/backend/logs /app/backend/dist && \
    chown -R 1000:1000 /app/logs /app/backend/logs /app/backend/dist && \
    chown 1000:1000 /app

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/health', (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }).on('error', () => process.exit(1))"

# Development command — build first, then run NestJS
# Note: tsx doesn't support parameter decorators, so we compile first
CMD ["sh", "-c", "cd backend && pnpm run build && node dist/nest/main.js"]
