# Development Dockerfile für Live-Reload
FROM node:24.11.1-alpine

# Install development tools
# Fix CVE-2025-10966: Upgrade curl to latest available version
RUN apk add --no-cache curl jq && \
    apk upgrade --no-cache curl

# Install pnpm globally (pinned version matching packageManager field)
# tsx and nodemon are in devDependencies - no need to install globally!
# Note: CVE-2025-64118 (tar) is fixed via pnpm override in package.json
RUN npm install -g pnpm@10.26.0

# Arbeitsverzeichnis
WORKDIR /app

# Package files kopieren - pnpm workspace braucht alle package.json VORHER
COPY package.json ./
COPY pnpm-lock.yaml ./
COPY pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/
COPY backend/package.json ./backend/

# EINMAL installieren - pnpm findet automatisch alle Workspaces (frontend + backend)
# onlyBuiltDependencies in package.json verhindert build scripts während Docker build
RUN pnpm install --frozen-lockfile

# Der Rest wird über Volumes gemountet

# Port
EXPOSE 3000

# Development command
CMD ["pnpm", "run", "dev"]
