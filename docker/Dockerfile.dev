# syntax=docker/dockerfile:1
# =============================================================================
# Assixx Backend - Development Dockerfile
# =============================================================================
# Single-stage build for development with live-reload
#
# BuildKit Optimizations:
# - Cache mounts for pnpm store (faster rebuilds)
# =============================================================================

# Node version is configurable via docker-compose.yml build args
ARG NODE_VERSION=24.14.0-alpine3.22
FROM node:${NODE_VERSION}
LABEL org.opencontainers.image.authors="Assixx"

# Install development tools
RUN apk add --no-cache curl jq

# Install pnpm globally (pinned version matching packageManager field)
# Note: CVE-2025-64118 (tar) is fixed via pnpm override in package.json
# Fix CVE-2025-64756: Update npm to get patched glob (>=11.1.0)
# pnpm version is configurable for consistency across environments
ARG PNPM_VERSION=10.30.3
RUN npm install -g npm@11.9.0 "pnpm@${PNPM_VERSION}"

WORKDIR /app

# Package files — pnpm workspace needs all package.json before install
COPY package.json .npmrc pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/
COPY backend/package.json ./backend/
COPY shared/package.json ./shared/

# Shared source (inject-workspace-packages needs source at install time)
COPY shared/ ./shared/

# Install all workspace dependencies with BuildKit cache mount
# Cache persists between builds, so unchanged packages don't need re-download
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# Create writable directories and fix permissions
# Only chown specific dirs (not node_modules — would take 100+ seconds!)
RUN mkdir -p /app/logs /app/backend/logs /app/backend/dist && \
    chown -R 1000:1000 /app/logs /app/backend/logs /app/backend/dist && \
    chown 1000:1000 /app

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/health', (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }).on('error', () => process.exit(1))"

# Development command — build first, then run NestJS
# Note: tsx doesn't support parameter decorators, so we compile first
CMD ["sh", "-c", "cd backend && pnpm run build && node dist/nest/main.js"]
