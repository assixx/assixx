# =============================================================================
# Assixx Docker Environment Configuration
# =============================================================================
#
# SECURITY INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace ALL placeholder values with your actual secrets
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. For production: Generate cryptographically secure secrets
# 5. Rotate secrets immediately if they are ever exposed
#
# SECRET GENERATION COMMANDS:
#   Strong password:  openssl rand -base64 32
#   JWT secret (hex): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# =============================================================================

# -----------------------------------------------------------------------------
# Compose Profile (controls which services start with `docker-compose up -d`)
# -----------------------------------------------------------------------------
# ADR-027 §"Decision 3 — pnpm deploy for Backend" (2026-04-27): Backend hat
# jetzt zwei Service-Definitionen — `backend` (dev, Dockerfile.dev, live-reload)
# und `backend-prod` (production, Dockerfile, compiled image, fast cold-start).
# Profile entscheidet welcher läuft:
#   COMPOSE_PROFILES=dev        → backend + deletion-worker (Default für Development)
#   COMPOSE_PROFILES=production → backend-prod + deletion-worker-prod + frontend + nginx
# Override per-Befehl: `docker-compose --profile production up -d`
COMPOSE_PROFILES=dev

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# SECURITY: Use strong, unique passwords in production!
# Generate with: openssl rand -base64 32
POSTGRES_USER=assixx_user
POSTGRES_PASSWORD=CHANGE_ME_USER_PASSWORD
POSTGRES_DB=assixx

# Backend uses these names (must match POSTGRES_* values)
DB_USER=assixx_user
DB_PASSWORD=CHANGE_ME_USER_PASSWORD
DB_NAME=assixx
DB_HOST=postgres
DB_PORT=5432

# System user (BYPASSRLS) for cron jobs, auth, root operations
# See ADR-019: Multi-Tenant RLS Isolation
# Must match password in docker/postgres-init/003_create_system_user.sql
DB_SYSTEM_USER=sys_user
DB_SYSTEM_PASSWORD=DevOnlySysP@ss2026!Rotate4Prod

# -----------------------------------------------------------------------------
# Application Secrets
# -----------------------------------------------------------------------------
# CRITICAL: Generate unique secrets for production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS_XXXXXXXXXXXXXXXX
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS_XXX
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_32_CHARS_XXXXXXXXX

# -----------------------------------------------------------------------------
# Microsoft OAuth Sign-In (Optional, Root-User Signup via Azure AD)
# -----------------------------------------------------------------------------
# ADR-046: One-click tenant-owner signup via Microsoft 365.
# Setup guide: docs/how-to/HOW-TO-AZURE-AD-SETUP.md
# Real secrets live in Doppler: docs/how-to/HOW-TO-DOPPLER-GUIDE.md
#
# PUBLIC_APP_URL is the single source of truth for the OAuth redirect URI
# (R4 mitigation). Backend derives ${PUBLIC_APP_URL}/api/v2/auth/oauth/microsoft/callback
# at boot — must match an entry in the Azure AD app registration.
#
# Values below are DEV/CI placeholders only. docker-compose.yml uses
# ${VAR:?msg} fail-fast guards, so these variables MUST be set — doppler run
# injects the real values in dev/prod.
PUBLIC_APP_URL=http://localhost:3000
MICROSOFT_OAUTH_CLIENT_ID=CHANGE_ME_AZURE_APP_ID
MICROSOFT_OAUTH_CLIENT_SECRET=CHANGE_ME_AZURE_CLIENT_SECRET

# -----------------------------------------------------------------------------
# SMTP Email Configuration
# -----------------------------------------------------------------------------
# For Gmail: Enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_MIN_16_CHARS

# -----------------------------------------------------------------------------
# SSL/TLS Configuration (Production only)
# -----------------------------------------------------------------------------
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# -----------------------------------------------------------------------------
# Tenant Deletion Configuration
# -----------------------------------------------------------------------------
# Production values (recommended):
DELETION_GRACE_PERIOD_DAYS=30
DELETION_COOLING_OFF_HOURS=24

# For testing (set to 0 to skip waiting periods):
# DELETION_GRACE_PERIOD_DAYS=0
# DELETION_COOLING_OFF_HOURS=0

# -----------------------------------------------------------------------------
# Sentry Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/
# Leave empty to disable Sentry in local development
#
# Backend DSN (NestJS):
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
#
# Frontend DSN (SvelteKit) - PUBLIC_ prefix required for browser access:
# PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
#
# Optional release tracking:
# SENTRY_RELEASE=assixx@1.0.0
#
# Debug mode (causes massive log spam - only for debugging Sentry itself):
# SENTRY_DEBUG=false

# -----------------------------------------------------------------------------
# PLG Stack - Observability (Optional)
# -----------------------------------------------------------------------------
# Start with: docker-compose --profile production up -d
#
# Loki - Log Aggregation (Dual Target Support)
# Logs can be sent to BOTH local Loki AND Grafana Cloud simultaneously!
#
# Local Docker Loki (default, always enabled with production profile):
# LOKI_LOCAL_URL=http://loki:3100
#
# Grafana Cloud (optional, requires credentials):
# Get credentials from: https://grafana.com/orgs/YOUR_ORG/stacks
# LOKI_URL=https://logs-prod-012.grafana.net
# GRAFANA_CLOUD_USER=123456
# GRAFANA_CLOUD_API_KEY=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Example configurations:
# - Local only: LOKI_LOCAL_URL=http://loki:3100 (default)
# - Cloud only: LOKI_URL=https://... + credentials
# - Both: Set both LOKI_LOCAL_URL and LOKI_URL + credentials
#
# Grafana - Dashboards (self-hosted)
# Access: http://localhost:3050
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=admin
# GF_ROOT_URL=http://localhost:3050
# GF_ANONYMOUS_ENABLED=false
#
# Prometheus scrapes /api/v2/metrics from backend automatically

# -----------------------------------------------------------------------------
# Alerting — Grafana + Sentry notification targets
# -----------------------------------------------------------------------------
# Values here are placeholders. Real values live in Doppler (per environment:
# dev / stg / prd). See docs/how-to/HOW-TO-ALERTING.md for the full setup.
#
# Grafana sends emails through the same SMTP_* secrets configured above.
# ALERT_EMAIL_TO is mandatory for alerts to reach anyone. ALERT_EMAIL_FROM
# falls back to SMTP_FROM if not set. SLACK_WEBHOOK_URL is optional —
# if unset, the slack-critical contact point provisions but delivers nothing.
#
# ALERT_EMAIL_TO=oncall@example.com
# ALERT_EMAIL_FROM=alerts@example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
#
# Sentry alert-rule provisioning (one-time setup, see scripts/sentry-setup-alerts.sh).
#
# IMPORTANT: Alert rules need a USER AUTH TOKEN, not an Org Auth Token.
# Org Auth Tokens (sntrys_ prefix) are used for source map uploads — their
# scope set does NOT include alerts:write. Keep them separate.
#
# SENTRY_ALERTS_TOKEN — User Auth Token with scope alerts:write.
#   Create at: https://sentry.io/settings/account/api/auth-tokens/
#   → "Create New Token" → Scopes: alerts:write (+ project:read to list rules)
# SENTRY_ORG_SLUG — Sentry organization slug (e.g. "assixx").
# SENTRY_PROJECT_SLUG_BACKEND / _FRONTEND — the two project slugs.
#
# SENTRY_ALERTS_TOKEN=sntryu_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG_SLUG=your-org
# SENTRY_PROJECT_SLUG_BACKEND=node-nestjs
# SENTRY_PROJECT_SLUG_FRONTEND=javascript-sveltekit

# -----------------------------------------------------------------------------
# Docker User/Group IDs
# -----------------------------------------------------------------------------
# Run 'id -u' and 'id -g' to get your values
USER_ID=1000
GROUP_ID=1000
