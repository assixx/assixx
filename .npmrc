engine-strict=true
save-exact=true

# Verhindert versehentliches npm install
# Nur pnpm ist erlaubt!

# Unterdrückt die "Ignored build scripts" Warnung
# Skripte bleiben blockiert (via package.json onlyBuiltDependencies: [])
# Die Warnung ist nur informativ - sie bestätigt dass Skripte blockiert sind
ignore-scripts=true

# pnpm v10+ modern deploy support
# Ermöglicht pnpm deploy ohne --legacy flag
inject-workspace-packages=true