{
  "migrations-dir": "database/migrations",
  "migrations-table": "pgmigrations",
  "schema": "public",
  "check-order": true,
  "verbose": true,
  "decamelize": true,
  "migration-filename-format": "utc",
  "migration-file-language": "ts",
  "template-file-name": "database/migrations/template.ts",
  "ignore-pattern": "template\\.ts"
}
