meta {
  name: List Chat Folders
  type: http
  seq: 2
}

get {
  url: {{base_url}}/documents/chat-folders
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return chat folders array", function() {
    expect(res.getBody().data.folders).to.be.an("array");
  });
}
