meta {
  name: List Documents
  type: http
  seq: 1
}

get {
  url: {{base_url}}/documents
  body: none
  auth: bearer
}

params:query {
  ~page: 1
  ~limit: 20
  ~folderId:
  ~search:
  ~type:
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return documents array", function() {
    // API returns: { data: { documents: [...], pagination: {...} } }
    expect(res.getBody().data.documents).to.be.an("array");
  });
}
