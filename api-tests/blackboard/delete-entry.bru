meta {
  name: Delete Entry (Admin)
  type: http
  seq: 11
}

delete {
  url: {{base_url}}/blackboard/entries/{{blackboard_entry_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_blackboard_id", "");
  const fallback = bru.getVar("existing_blackboard_id");
  if (fallback) {
    bru.setVar("blackboard_entry_id", fallback);
  }
}
