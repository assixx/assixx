meta {
  name: Get Entry Full (with comments and attachments)
  type: http
  seq: 3
}

get {
  url: {{base_url}}/blackboard/entries/{{blackboard_entry_id}}/full
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return entry with comments and attachments", function() {
    expect(res.getBody().data).to.have.property("entry");
    expect(res.getBody().data).to.have.property("comments");
    expect(res.getBody().data).to.have.property("attachments");
  });
}
