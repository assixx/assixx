meta {
  name: Get Blackboard Entry
  type: http
  seq: 2
}

get {
  url: {{base_url}}/blackboard/entries/{{blackboard_entry_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return entry object", function() {
    expect(res.getBody().data).to.have.property("id");
    expect(res.getBody().data).to.have.property("title");
  });
}
