meta {
  name: Add Comment to Entry
  type: http
  seq: 8
}

post {
  url: {{base_url}}/blackboard/entries/{{blackboard_entry_id}}/comments
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "comment": "This is a test comment from Bruno API testing.",
    "isInternal": false
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
