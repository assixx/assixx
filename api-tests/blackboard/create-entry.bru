meta {
  name: Create Blackboard Entry (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/blackboard/entries
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Bruno Test {{$timestamp}}",
    "content": "Created via Bruno API test - will be deleted",
    "priority": "medium",
    "orgLevel": "company",
    "requiresConfirmation": false
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created entry", function() {
    expect(res.getBody().data).to.have.property("id");
    expect(res.getBody().data.title).to.include("Bruno Test");
  });
}

script:post-response {
  if (res.body.data && res.body.data.id) {
    bru.setVar("blackboard_entry_id", res.body.data.id);
    bru.setVar("created_blackboard_id", res.body.data.id);
  }
}
