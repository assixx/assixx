meta {
  name: Confirm Entry (Mark as Read)
  type: http
  seq: 6
}

post {
  url: {{base_url}}/blackboard/entries/{{blackboard_entry_id}}/confirm
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {}
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
