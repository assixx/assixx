meta {
  name: Get Dashboard Entries
  type: http
  seq: 9
}

get {
  url: {{base_url}}/blackboard/dashboard
  body: none
  auth: bearer
}

params:query {
  ~limit: 5
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return dashboard entries", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}
