meta {
  name: Get Current User (me)
  type: http
  seq: 1
}

get {
  url: {{base_url}}/users/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.id: isNumber
  res.body.data.email: isString
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return user data", function() {
    const user = res.getBody().data;
    expect(user).to.have.property("id");
    expect(user).to.have.property("email");
    expect(user).to.have.property("role");
    expect(user).to.have.property("firstName");
    expect(user).to.have.property("lastName");
  });

  test("should not expose password", function() {
    const user = res.getBody().data;
    expect(user).to.not.have.property("password");
  });

  test("should return tenant info", function() {
    const user = res.getBody().data;
    // User should have tenant association
    expect(user).to.have.property("tenantId");
    // Team fields are optional (only present if user is assigned to a team)
  });
}
