meta {
  name: List Users (Admin)
  type: http
  seq: 2
}

get {
  url: {{base_url}}/users
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 10
  ~search:
  ~role: employee
  ~isActive: 1
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return array of users", function() {
    // API returns: { data: [...], meta: { pagination: {...} } }
    expect(res.getBody().data).to.be.an("array");
  });

  test("should return pagination info", function() {
    const body = res.getBody();
    expect(body.meta).to.have.property("pagination");
    // API returns: currentPage, totalPages, pageSize, totalItems
    expect(body.meta.pagination).to.have.property("totalItems");
    expect(body.meta.pagination).to.have.property("currentPage");
    expect(body.meta.pagination).to.have.property("pageSize");
  });
}
