meta {
  name: Delete Rotation History (Cleanup)
  type: http
  seq: 5
}

delete {
  url: {{base_url}}/shifts/rotation/history?teamId={{team_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return success message", function() {
    expect(res.getBody()).to.have.property("data");
  });

  test("should return deletedCounts", function() {
    const data = res.getBody().data;
    expect(data).to.have.property("deletedCounts");
  });
}
