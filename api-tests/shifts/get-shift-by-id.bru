meta {
  name: Get Shift by ID
  type: http
  seq: 2
}

get {
  url: {{base_url}}/shifts/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: in [200, 404]
}

tests {
  test("should return 200 OK or 404 Not Found", function() {
    const status = res.getStatus();
    expect([200, 404]).to.include(status);
  });

  test("should return shift object or not found error", function() {
    if (res.getStatus() === 200) {
      const shift = res.getBody().data;
      expect(shift).to.have.property("id");
    } else {
      expect(res.getBody().success).to.be.false;
    }
  });
}
