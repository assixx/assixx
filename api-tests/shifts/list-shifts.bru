meta {
  name: List Shifts
  type: http
  seq: 1
}

get {
  url: {{base_url}}/shifts
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~startDate: 2025-01-01
  ~endDate: 2025-12-31
  ~userId:
  ~departmentId:
  ~status: planned
  ~type: regular
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return shifts array", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}

script:post-response {
  if (res.body.data && res.body.data.length > 0) {
    bru.setVar("shift_id", res.body.data[0].id);
  }
}
