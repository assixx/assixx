meta {
  name: Delete Shifts by Week (Cleanup)
  type: http
  seq: 4
}

delete {
  url: {{base_url}}/shifts/week?teamId={{team_id}}&startDate=2025-01-20&endDate=2025-01-31
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return shiftsDeleted count", function() {
    expect(res.getBody().data).to.have.property("shiftsDeleted");
  });

  test("should have deleted at least 0 shifts", function() {
    expect(res.getBody().data.shiftsDeleted).to.be.at.least(0);
  });
}
