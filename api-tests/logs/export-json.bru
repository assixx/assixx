meta {
  name: Export Logs (JSON)
  type: http
  seq: 1
}

get {
  url: {{base_url}}/logs/export?format=json&dateFrom=2026-01-01&dateTo=2026-01-31&source=all
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.headers.content-type: contains application/json
  res.headers.content-disposition: contains attachment
  res.headers.content-disposition: contains audit-logs-export
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return JSON content-type", function() {
    expect(res.getHeader("content-type")).to.include("application/json");
  });

  test("should have Content-Disposition header for download", function() {
    const disposition = res.getHeader("content-disposition");
    expect(disposition).to.include("attachment");
    expect(disposition).to.include(".json");
  });

  test("should return valid JSON array", function() {
    const body = res.getBody();
    expect(body).to.be.an("array");
  });

  test("if entries exist, should have correct structure", function() {
    const body = res.getBody();
    if (body.length > 0) {
      const entry = body[0];
      expect(entry).to.have.property("id");
      expect(entry).to.have.property("timestamp");
      expect(entry).to.have.property("tenantId");
      expect(entry).to.have.property("userId");
      expect(entry).to.have.property("action");
      expect(entry).to.have.property("source");
      expect(entry.source).to.be.oneOf(["audit_trail", "root_logs"]);
    }
  });
}
