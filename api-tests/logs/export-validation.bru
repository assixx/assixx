meta {
  name: Export Logs (Validation Errors)
  type: http
  seq: 4
}

get {
  url: {{base_url}}/logs/export?format=json
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 Bad Request when dateFrom is missing", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should have error message about missing date", function() {
    const body = res.getBody();
    // Zod validation error format
    expect(body.success).to.be.false;
  });
}
