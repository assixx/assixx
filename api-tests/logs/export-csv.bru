meta {
  name: Export Logs (CSV)
  type: http
  seq: 2
}

get {
  url: {{base_url}}/logs/export?format=csv&dateFrom=2026-01-01&dateTo=2026-01-31&source=all
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.headers.content-type: contains text/csv
  res.headers.content-disposition: contains attachment
  res.headers.content-disposition: contains .csv
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return CSV content-type", function() {
    expect(res.getHeader("content-type")).to.include("text/csv");
  });

  test("should have Content-Disposition header for download", function() {
    const disposition = res.getHeader("content-disposition");
    expect(disposition).to.include("attachment");
    expect(disposition).to.include(".csv");
  });

  test("should have CSV header row", function() {
    const body = res.getBody();
    const firstLine = body.split("\n")[0];
    expect(firstLine).to.include("ID");
    expect(firstLine).to.include("Timestamp");
    expect(firstLine).to.include("Source");
    expect(firstLine).to.include("Action");
  });
}
