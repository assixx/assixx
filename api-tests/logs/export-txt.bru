meta {
  name: Export Logs (TXT)
  type: http
  seq: 3
}

get {
  url: {{base_url}}/logs/export?format=txt&dateFrom=2026-01-01&dateTo=2026-01-31&source=all
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.headers.content-type: contains text/plain
  res.headers.content-disposition: contains attachment
  res.headers.content-disposition: contains .txt
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return TXT content-type", function() {
    expect(res.getHeader("content-type")).to.include("text/plain");
  });

  test("should have Content-Disposition header for download", function() {
    const disposition = res.getHeader("content-disposition");
    expect(disposition).to.include("attachment");
    expect(disposition).to.include(".txt");
  });

  test("should have ASSIXX AUDIT LOG EXPORT header", function() {
    const body = res.getBody();
    expect(body).to.include("ASSIXX AUDIT LOG EXPORT");
  });

  test("should have END OF EXPORT footer", function() {
    const body = res.getBody();
    expect(body).to.include("END OF EXPORT");
  });

  test("should have separator lines", function() {
    const body = res.getBody();
    expect(body).to.include("================");
  });
}
