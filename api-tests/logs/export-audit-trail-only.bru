meta {
  name: Export Audit Trail Only
  type: http
  seq: 6
}

get {
  url: {{base_url}}/logs/export?format=json&dateFrom=2026-01-01&dateTo=2026-01-31&source=audit_trail
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.headers.content-type: contains application/json
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return valid JSON array", function() {
    const body = res.getBody();
    expect(body).to.be.an("array");
  });

  test("if entries exist, all should be from audit_trail source", function() {
    const body = res.getBody();
    if (body.length > 0) {
      body.forEach(entry => {
        expect(entry.source).to.equal("audit_trail");
      });
    }
  });
}
