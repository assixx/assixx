meta {
  name: Create Chat Conversation
  type: http
  seq: 2
}

post {
  url: {{base_url}}/chat/conversations
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "participantIds": [{{chat_participant_id}}],
    "type": "direct"
  }
}

auth:bearer {
  token: {{auth_token}}
}

script:pre-request {
  // Get a valid user ID from the same tenant for the conversation
  const baseUrl = bru.getEnvVar('base_url');
  const token = bru.getVar('auth_token');
  const currentUserId = bru.getVar('user_id');

  // Fetch users and pick one that's not the current user
  await bru.sendRequest({
    method: 'GET',
    url: `${baseUrl}/users?limit=10`,
    headers: { 'Authorization': `Bearer ${token}` }
  }, function(err, response) {
    // API returns { success: true, data: [...users...] }
    // So response.data.data is the users array
    if (!err && response.data && response.data.data && Array.isArray(response.data.data)) {
      const users = response.data.data;
      // Find a user different from current user
      const otherUser = users.find(u => u.id !== currentUserId);
      if (otherUser) {
        bru.setVar('chat_participant_id', otherUser.id);
      } else if (users.length > 0) {
        bru.setVar('chat_participant_id', users[0].id);
      }
    }
  });
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return conversation with ID", function() {
    expect(res.getBody().data.conversation).to.have.property("id");
  });
}

script:post-response {
  if (res.body.data && res.body.data.conversation && res.body.data.conversation.id) {
    bru.setVar("conversation_id", res.body.data.conversation.id);
  }
}
