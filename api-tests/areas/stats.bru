meta {
  name: Get Area Statistics
  type: http
  seq: 2
}

get {
  url: {{base_url}}/areas/stats
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
