meta {
  name: Delete Notification
  type: http
  seq: 8
}

delete {
  url: {{base_url}}/notifications/{{notification_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_notification_id", "");
  const fallback = bru.getVar("existing_notification_id");
  if (fallback) {
    bru.setVar("notification_id", fallback);
  }
}
