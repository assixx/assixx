meta {
  name: Mark Notification as Read
  type: http
  seq: 5
}

put {
  url: {{base_url}}/notifications/{{notification_id}}/read
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
