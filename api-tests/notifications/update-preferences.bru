meta {
  name: Update Notification Preferences
  type: http
  seq: 4
}

put {
  url: {{base_url}}/notifications/preferences
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "emailEnabled": true,
    "pushEnabled": true,
    "categories": {
      "system": true,
      "chat": true,
      "blackboard": true
    }
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
