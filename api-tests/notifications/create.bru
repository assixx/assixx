meta {
  name: Create Notification (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/notifications
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Bruno Test {{$timestamp}}",
    "message": "Created via Bruno API test - will be deleted",
    "type": "announcement",
    "recipientType": "all"
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}

script:post-response {
  // API returns: { data: { notificationId: X } }
  if (res.body.data && res.body.data.notificationId) {
    bru.setVar("notification_id", res.body.data.notificationId);
  }
}
