meta {
  name: Create Team (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/teams
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Bruno Test Team {{$timestamp}}",
    "departmentId": {{teams_department_id}},
    "description": "Created via Bruno API test - will be deleted"
  }
}

auth:bearer {
  token: {{auth_token}}
}

script:pre-request {
  // Create a department for this team test using Bruno's built-in request
  const baseUrl = bru.getEnvVar('base_url');
  const token = bru.getVar('auth_token');

  await bru.sendRequest({
    method: 'POST',
    url: `${baseUrl}/departments`,
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`
    },
    data: {
      name: `Teams Test Dept ${Date.now()}`,
      description: 'Auto-created for teams test'
    }
  }, function(err, response) {
    if (!err && response.data && response.data.data && response.data.data.id) {
      bru.setVar('teams_department_id', response.data.data.id);
    }
  });
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created team with ID", function() {
    expect(res.getBody().data).to.have.property("id");
  });
}

script:post-response {
  // Store created team ID for subsequent tests
  if (res.body.data && res.body.data.id) {
    bru.setVar("team_id", res.body.data.id);
    bru.setVar("created_team_id", res.body.data.id);
  }
}
