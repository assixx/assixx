meta {
  name: List Features
  type: http
  seq: 1
}

get {
  url: {{base_url}}/features
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return features array", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}
