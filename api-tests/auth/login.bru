meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{brunotest_email}}",
    "password": "{{brunotest_password}}"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.accessToken: isString
  res.body.data.refreshToken: isString
  res.body.data.user.id: isNumber
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return success true", function() {
    expect(res.getBody().success).to.be.true;
  });

  test("should return access token", function() {
    expect(res.getBody().data).to.have.property("accessToken");
    expect(res.getBody().data.accessToken).to.be.a("string");
  });

  test("should return refresh token", function() {
    expect(res.getBody().data).to.have.property("refreshToken");
    expect(res.getBody().data.refreshToken).to.be.a("string");
  });

  test("should return user data", function() {
    expect(res.getBody().data).to.have.property("user");
    expect(res.getBody().data.user).to.have.property("id");
    expect(res.getBody().data.user).to.have.property("email");
    expect(res.getBody().data.user).to.have.property("role");
  });
}

script:post-response {
  // Store tokens and user data for subsequent requests
  if (res.body.data && res.body.data.accessToken) {
    bru.setVar("auth_token", res.body.data.accessToken);
    bru.setVar("refresh_token", res.body.data.refreshToken);
  }
  if (res.body.data && res.body.data.user) {
    bru.setVar("user_id", res.body.data.user.id);
    bru.setVar("tenant_id", res.body.data.user.tenantId);
  }
}
