meta {
  name: List Surveys
  type: http
  seq: 1
}

get {
  url: {{base_url}}/surveys
  body: none
  auth: bearer
}

params:query {
  ~page: 1
  ~limit: 20
  ~status: active
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return surveys array", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}

script:post-response {
  if (res.body.data && res.body.data.length > 0) {
    bru.setVar("existing_survey_id", res.body.data[0].id);
  }
}
