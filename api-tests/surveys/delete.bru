meta {
  name: Delete Survey (Admin)
  type: http
  seq: 7
}

delete {
  url: {{base_url}}/surveys/{{survey_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_survey_id", "");
  const fallback = bru.getVar("existing_survey_id");
  if (fallback) {
    bru.setVar("survey_id", fallback);
  }
}
