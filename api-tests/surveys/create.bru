meta {
  name: Create Survey (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/surveys
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Bruno Test {{$timestamp}}",
    "description": "Created via Bruno API test - will be deleted",
    "status": "draft",
    "questions": [
      {
        "questionText": "Test question?",
        "questionType": "rating",
        "isRequired": true
      }
    ]
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}

script:post-response {
  if (res.body.data && res.body.data.id) {
    bru.setVar("survey_id", res.body.data.id);
    bru.setVar("created_survey_id", res.body.data.id);
  }
}
