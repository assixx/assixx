meta {
  name: Delete KVP Suggestion
  type: http
  seq: 10
}

delete {
  url: {{base_url}}/kvp/{{kvp_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_kvp_id", "");
  const fallback = bru.getVar("existing_kvp_id");
  if (fallback) {
    bru.setVar("kvp_id", fallback);
  }
}
