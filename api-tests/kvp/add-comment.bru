meta {
  name: Add KVP Comment
  type: http
  seq: 8
}

post {
  url: {{base_url}}/kvp/{{kvp_id}}/comments
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "comment": "This is a test comment on the KVP suggestion.",
    "isInternal": false
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
