meta {
  name: Create KVP Suggestion
  type: http
  seq: 2
}

post {
  url: {{base_url}}/kvp
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Bruno Test {{$timestamp}}",
    "description": "Created via Bruno API test - this is a test KVP entry that will be deleted after testing",
    "categoryId": 1,
    "orgLevel": "company",
    "orgId": 1,
    "priority": "normal",
    "expectedBenefit": "Test benefit for automation testing"
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}

script:post-response {
  if (res.body.data && res.body.data.id) {
    bru.setVar("kvp_id", res.body.data.id);
    bru.setVar("created_kvp_id", res.body.data.id);
  }
}
