meta {
  name: Create Machine (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/machines
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Bruno Test {{$timestamp}}",
    "model": "TM-001",
    "manufacturer": "Bruno Test Corp",
    "machineType": "production",
    "status": "operational",
    "location": "Test Location"
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });
}

script:post-response {
  if (res.body.data && res.body.data.id) {
    bru.setVar("machine_id", res.body.data.id);
    bru.setVar("created_machine_id", res.body.data.id);
  }
}
