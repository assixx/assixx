meta {
  name: Get Maintenance History
  type: http
  seq: 8
}

get {
  url: {{base_url}}/machines/{{machine_id}}/maintenance
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return maintenance history array", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}
