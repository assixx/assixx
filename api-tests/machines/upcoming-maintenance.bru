meta {
  name: Get Upcoming Maintenance
  type: http
  seq: 7
}

get {
  url: {{base_url}}/machines/upcoming-maintenance
  body: none
  auth: bearer
}

params:query {
  ~days: 30
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return machines needing maintenance", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}
