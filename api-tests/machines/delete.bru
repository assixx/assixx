meta {
  name: Delete Machine (Admin)
  type: http
  seq: 9
}

delete {
  url: {{base_url}}/machines/{{machine_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_machine_id", "");
  const fallback = bru.getVar("existing_machine_id");
  if (fallback) {
    bru.setVar("machine_id", fallback);
  }
}
