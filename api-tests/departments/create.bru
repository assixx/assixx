meta {
  name: Create Department (Admin)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/departments
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Bruno Test Dept {{$timestamp}}",
    "description": "Created via Bruno API test - will be deleted"
  }
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

tests {
  test("should return 201 Created", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created department with ID", function() {
    expect(res.getBody().data).to.have.property("id");
  });
}

script:post-response {
  // Store created department ID for subsequent tests
  if (res.body.data && res.body.data.id) {
    bru.setVar("department_id", res.body.data.id);
    bru.setVar("created_department_id", res.body.data.id);
  }
}
