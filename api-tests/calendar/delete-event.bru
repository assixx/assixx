meta {
  name: Delete Calendar Event
  type: http
  seq: 5
}

delete {
  url: {{base_url}}/calendar/events/{{calendar_event_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

script:post-response {
  bru.setVar("created_calendar_id", "");
  const fallback = bru.getVar("existing_calendar_id");
  if (fallback) {
    bru.setVar("calendar_event_id", fallback);
  }
}
