meta {
  name: Create Brunotest Tenant
  type: http
  seq: 2
}

post {
  url: {{base_url}}/signup
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "companyName": "Bruno Test GmbH",
    "subdomain": "brunotest",
    "email": "info@brunotest.de",
    "phone": "+49 123 456789",
    "address": "Teststrasse 1, 12345 Teststadt",
    "adminEmail": "admin@brunotest.de",
    "adminPassword": "BrunoTest123!",
    "adminFirstName": "Bruno",
    "adminLastName": "Tester",
    "plan": "trial"
  }
}

tests {
  test("should return 201 Created OR 409 Conflict (tenant exists)", function() {
    const status = res.getStatus();
    // 201 = New tenant created
    // 409 = Tenant already exists (also OK!)
    expect([201, 409]).to.include(status);
  });

  test("should handle response correctly", function() {
    const status = res.getStatus();
    if (status === 201) {
      // New tenant created
      expect(res.getBody().data).to.have.property("tenantId");
      expect(res.getBody().data).to.have.property("userId");
      expect(res.getBody().data.subdomain).to.equal("brunotest");
    } else if (status === 409) {
      // Tenant already exists - this is fine!
      expect(res.getBody().error).to.have.property("message");
    }
  });
}

script:post-response {
  // Store tenant info if created successfully
  const status = res.getStatus();
  if (status === 201 && res.body.data) {
    bru.setVar("brunotest_tenant_id", res.body.data.tenantId);
    bru.setVar("brunotest_user_id", res.body.data.userId);
    console.log("Brunotest tenant created: ID=" + res.body.data.tenantId);
  } else if (status === 409) {
    console.log("Brunotest tenant already exists - proceeding to login");
  }
}
