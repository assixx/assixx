meta {
  name: Check Brunotest Subdomain
  type: http
  seq: 1
}

get {
  url: {{base_url}}/signup/check-subdomain/brunotest
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return subdomain check result", function() {
    expect(res.getBody().data).to.have.property("available");
    expect(res.getBody().data).to.have.property("subdomain");
    expect(res.getBody().data.subdomain).to.equal("brunotest");
  });
}

script:post-response {
  // Store availability status for conditional tenant creation
  if (res.body.data) {
    bru.setVar("brunotest_available", res.body.data.available);
  }
}
